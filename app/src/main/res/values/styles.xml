<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TopRoundedImage">
        <item name="cornerSizeTopLeft">@dimen/item_card_corner_radius</item>
        <item name="cornerSizeTopRight">@dimen/item_card_corner_radius</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="BottomCard">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="NearbyEventChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/bg_chip_selector</item>
        <item name="android:textColor">@color/text_chip_selector</item>
        <item name="chipStrokeColor">@color/colorLightGray</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">@dimen/chip_radius</item>
        <item name="android:textSize">13sp</item>
        <item name="chipIconVisible">false</item>
        <item name="closeIconVisible">false</item>
    </style>

    <style name="ExpandedTitleTextAppearance" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
