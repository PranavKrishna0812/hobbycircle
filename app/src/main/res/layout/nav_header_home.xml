<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorNavy"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:id="@+id/tvUserInitial"
        android:layout_width="@dimen/header_initial_size"
        android:layout_height="@dimen/header_initial_size"
        android:background="@drawable/bg_white_circle"
        android:gravity="center"
        android:text="U"
        android:textColor="@color/colorNavy"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvHeaderName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/poppins_semibold"
        android:text="User Name"
        android:textColor="@color/colorWhite"
        android:textSize="@dimen/header_name_text_size" />

    <TextView
        android:id="@+id/tvHeaderEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/dm_sans_regular"
        android:text="user@example.com"
        android:textColor="@color/colorTextMuted"
        android:textSize="@dimen/header_email_text_size" />

</LinearLayout>
