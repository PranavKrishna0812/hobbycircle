<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/authRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hc_bg">

    <!-- Background image -->
    <ImageView
        android:id="@+id/ivAuthBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.15"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_3" />

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_auth_overlay" />

    <ScrollView
        android:id="@+id/authScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingLeft="32dp"
        android:paddingTop="32dp"
        android:paddingRight="32dp"
        android:paddingBottom="42dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Auth card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="100dp"
                android:background="@drawable/bg_auth_card"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Google Sign In -->
                <Button
                    android:id="@+id/btnGoogleSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/ripple_primary_button"
                    android:text="Continue with Google"
                    android:textAllCaps="false"
                    android:textColor="@color/hc_button_text_on_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDividerText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:text="or use email"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="12sp" />

                <!-- EMAIL label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="EMAIL"
                    android:textAllCaps="true"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="Email address"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/hc_text_primary"
                    android:textColorHint="@color/hc_text_secondary" />

                <!-- PASSWORD label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:letterSpacing="0.06"
                    android:text="PASSWORD"
                    android:textAllCaps="true"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:textColor="@color/hc_text_primary"
                    android:textColorHint="@color/hc_text_secondary" />

                <!-- CONFIRM PASSWORD label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:letterSpacing="0.06"
                    android:text="CONFIRM PASSWORD"
                    android:textAllCaps="true"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="Confirm password (for registration)"
                    android:inputType="textPassword"
                    android:textColor="@color/hc_text_primary"
                    android:textColorHint="@color/hc_text_secondary" />

                <!-- Login / Register row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnLogin"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/ripple_primary_button"
                        android:text="Login"
                        android:textAllCaps="false"
                        android:textColor="@color/hc_button_text_on_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnRegister"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/ripple_outline_button"
                        android:text="Register"
                        android:textAllCaps="false"
                        android:textColor="@color/hc_primary_light"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>