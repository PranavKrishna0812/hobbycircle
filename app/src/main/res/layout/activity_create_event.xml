<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/createEventRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hc_bg">

    <ScrollView
        android:id="@+id/createEventScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingLeft="32dp"
        android:paddingTop="32dp"
        android:paddingRight="32dp"
        android:paddingBottom="90dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/tvCreateEventTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Meetup"
                android:textColor="@color/hc_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Progress bar decoration -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:background="@color/hc_surface">

                <View
                    android:layout_width="120dp"
                    android:layout_height="4dp"
                    android:background="@color/hc_primary" />
            </FrameLayout>

            <!-- Form card with glassmorphism -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- EVENT IMAGE area -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ivEventImage"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop"
                        android:background="@color/hc_surface"
                        android:visibility="visible" /> <!-- Always visible for the border/bg to show -->

                    <Button
                        android:id="@+id/btnAddImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Add Cover Image"
                        android:backgroundTint="#00000000"
                        android:textColor="@color/hc_primary_light"
                        android:layout_gravity="center"
                        style="?attr/materialButtonOutlinedStyle"
                        app:strokeColor="@color/hc_primary" />
                </FrameLayout>

                <!-- EVENT TITLE label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="EVENT TITLE"
                    android:textAllCaps="true"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="Event title"
                    android:textColor="@color/hc_text_primary"
                    android:textColorHint="@color/hc_text_secondary" />

                <!-- DESCRIPTION label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:letterSpacing="0.06"
                    android:text="DESCRIPTION"
                    android:textAllCaps="true"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top|start"
                    android:hint="Description"
                    android:minLines="3"
                    android:textColor="@color/hc_text_primary"
                    android:textColorHint="@color/hc_text_secondary" />

                <!-- HOBBY TAG label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:letterSpacing="0.06"
                    android:text="HOBBY TAG"
                    android:textAllCaps="true"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etHobbyId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="Hobby tag (e.g. chess)"
                    android:textColor="@color/hc_text_primary"
                    android:textColorHint="@color/hc_text_secondary" />

                <!-- LOCATION label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:letterSpacing="0.06"
                    android:text="LOCATION"
                    android:textAllCaps="true"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:clickable="false"
                        android:focusable="false"
                        android:hint="No location selected"
                        android:textColor="@color/hc_text_primary"
                        android:textColorHint="@color/hc_text_secondary"
                        android:inputType="none" />

                    <Button
                        android:id="@+id/btnPickLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Map"
                        android:backgroundTint="@color/hc_surface"
                        android:textColor="@color/hc_primary_light"
                        style="?attr/materialButtonOutlinedStyle"
                        app:strokeColor="@color/hc_primary" />
                </LinearLayout>

                <!-- DATE & TIME label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:letterSpacing="0.06"
                    android:text="DATE &amp; TIME"
                    android:textAllCaps="true"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etEventTimeMillis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Select date and time"
                    android:inputType="none"
                    android:textColor="@color/hc_text_primary"
                    android:textColorHint="@color/hc_text_secondary" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Sticky bottom Publish button -->
    <Button
        android:id="@+id/btnCreateEvent"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="bottom"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/ripple_primary_button"
        android:text="🚀  Publish Meetup"
        android:textAllCaps="false"
        android:textColor="@color/hc_button_text_on_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

</FrameLayout>