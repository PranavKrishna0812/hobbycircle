<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorSurfaceVariant">

    <!-- AppBar & Stepper Indicator under shared BaseDrawerActivity top bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarCreate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorNavy"
        app:elevation="0dp">

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressStepper"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progress="25"
            app:indicatorColor="@color/hc_accent"
            app:trackColor="@color/colorPrimaryVariant" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content Forms -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="84dp"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD 1 — Basic Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/colorWhite"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="BASIC INFO"
                        android:textColor="@color/hc_accent"
                        android:textSize="13sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEventTitle"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Event title"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:startIconDrawable="@drawable/ic_title"
                        app:startIconTint="@color/hc_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/colorNavy" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEventDescription"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Describe your event..."
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:minLines="3"
                            android:textColor="@color/colorNavy" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilHobbyTag"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Hobby tag (e.g. Photography)"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:startIconDrawable="@drawable/ic_tag"
                        app:startIconTint="@color/hc_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etHobbyId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="@color/colorNavy" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilAttendeeLimit"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Attendee limit (optional, e.g. 10)"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:startIconDrawable="@drawable/ic_people"
                        app:startIconTint="@color/hc_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAttendeeLimit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/colorNavy" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- CARD 2 — Date & Time -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/colorWhite"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="DATE &amp; TIME"
                        android:textColor="@color/hc_accent"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Date Picker Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDatePicker"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/hc_bg"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:contentDescription="Calendar Icon"
                                    android:src="@drawable/ic_calendar"
                                    app:tint="@color/hc_accent" />

                                <TextView
                                    android:id="@+id/tvSelectedDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:gravity="center"
                                    android:text="Select Date"
                                    android:textColor="@color/colorNavy"
                                    android:textSize="14sp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <Space
                            android:layout_width="12dp"
                            android:layout_height="wrap_content" />

                        <!-- Time Picker Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardTimePicker"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/hc_bg"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:contentDescription="Clock Icon"
                                    android:src="@drawable/ic_time"
                                    app:tint="@color/hc_accent" />

                                <TextView
                                    android:id="@+id/tvSelectedTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:gravity="center"
                                    android:text="Select Time"
                                    android:textColor="@color/colorNavy"
                                    android:textSize="14sp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- CARD 3 — Location -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/colorWhite"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="LOCATION"
                        android:textColor="@color/hc_accent"
                        android:textSize="13sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLocation"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter location"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:startIconDrawable="@drawable/ic_location"
                        app:startIconTint="@color/hc_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress"
                            android:textColor="@color/colorNavy" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickOnMap"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Pick on Map"
                        android:textColor="@color/hc_accent"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_map"
                        app:iconTint="@color/hc_accent"
                        app:strokeColor="@color/hc_accent" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardMapPreview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivMapPreview"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:contentDescription="Map Thumbnail"
                            android:scaleType="centerCrop" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- CARD 4 — Cover Photo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/colorWhite"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="COVER PHOTO"
                        android:textColor="@color/hc_accent"
                        android:textSize="13sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardImagePicker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/hc_bg"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/colorLightGray"
                        app:strokeWidth="2dp">

                        <!-- Default Empty State -->
                        <LinearLayout
                            android:id="@+id/layoutPickerDefault"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="32dp">

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:contentDescription="Add Photo Icon"
                                android:src="@drawable/ic_add_photo"
                                app:tint="@color/hc_text_secondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Add Cover Photo"
                                android:textColor="@color/hc_text_secondary"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Optional · Tap to select"
                                android:textColor="@color/colorTextMuted"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <!-- Selected Preview State -->
                        <FrameLayout
                            android:id="@+id/layoutPickerPreview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/ivCoverPreview"
                                android:layout_width="match_parent"
                                android:layout_height="180dp"
                                android:scaleType="centerCrop"
                                app:shapeAppearanceOverlay="@style/TopRoundedImage" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnChangeCover"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:layout_margin="8dp"
                                android:alpha="0.8"
                                android:backgroundTint="@color/colorNavy"
                                android:text="Change"
                                android:textColor="@color/colorWhite"
                                android:textSize="12sp"
                                app:cornerRadius="8dp" />

                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="OR CHOOSE A PREMIUM PRESET"
                        android:textColor="@color/hc_text_secondary"
                        android:textSize="11sp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layoutPresets"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingBottom="4dp">

                            <!-- Preset 1: Sports -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/presetSports"
                                android:layout_width="88dp"
                                android:layout_height="64dp"
                                android:layout_marginEnd="8dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/colorLightGray"
                                app:strokeWidth="1dp">
                                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                    <ImageView
                                        android:id="@+id/ivPresetSports"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/bg_common" />
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#66000000" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="bottom|center_horizontal"
                                        android:layout_marginBottom="6dp"
                                        android:gravity="center"
                                        android:text="Sports"
                                        android:textColor="@color/colorWhite"
                                        android:textSize="11sp"
                                        android:fontFamily="sans-serif-medium" />
                                </FrameLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Preset 2: Music -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/presetMusic"
                                android:layout_width="88dp"
                                android:layout_height="64dp"
                                android:layout_marginEnd="8dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/colorLightGray"
                                app:strokeWidth="1dp">
                                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                    <ImageView
                                        android:id="@+id/ivPresetMusic"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/bg_common" />
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#66000000" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="bottom|center_horizontal"
                                        android:layout_marginBottom="6dp"
                                        android:gravity="center"
                                        android:text="Music"
                                        android:textColor="@color/colorWhite"
                                        android:textSize="11sp"
                                        android:fontFamily="sans-serif-medium" />
                                </FrameLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Preset 3: Gaming -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/presetGaming"
                                android:layout_width="88dp"
                                android:layout_height="64dp"
                                android:layout_marginEnd="8dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/colorLightGray"
                                app:strokeWidth="1dp">
                                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                    <ImageView
                                        android:id="@+id/ivPresetGaming"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/bg_common" />
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#66000000" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="bottom|center_horizontal"
                                        android:layout_marginBottom="6dp"
                                        android:gravity="center"
                                        android:text="Gaming"
                                        android:textColor="@color/colorWhite"
                                        android:textSize="11sp"
                                        android:fontFamily="sans-serif-medium" />
                                </FrameLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Preset 4: Creative -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/presetCreative"
                                android:layout_width="88dp"
                                android:layout_height="64dp"
                                android:layout_marginEnd="8dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/colorLightGray"
                                app:strokeWidth="1dp">
                                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                    <ImageView
                                        android:id="@+id/ivPresetCreative"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/bg_common" />
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#66000000" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="bottom|center_horizontal"
                                        android:layout_marginBottom="6dp"
                                        android:gravity="center"
                                        android:text="Creative"
                                        android:textColor="@color/colorWhite"
                                        android:textSize="11sp"
                                        android:fontFamily="sans-serif-medium" />
                                </FrameLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Preset 5: Reading -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/presetReading"
                                android:layout_width="88dp"
                                android:layout_height="64dp"
                                android:layout_marginEnd="8dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/colorLightGray"
                                app:strokeWidth="1dp">
                                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                    <ImageView
                                        android:id="@+id/ivPresetReading"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/bg_common" />
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#66000000" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="bottom|center_horizontal"
                                        android:layout_marginBottom="6dp"
                                        android:gravity="center"
                                        android:text="Reading"
                                        android:textColor="@color/colorWhite"
                                        android:textSize="11sp"
                                        android:fontFamily="sans-serif-medium" />
                                </FrameLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Preset 6: Social -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/presetSocial"
                                android:layout_width="88dp"
                                android:layout_height="64dp"
                                android:layout_marginEnd="8dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/colorLightGray"
                                app:strokeWidth="1dp">
                                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                    <ImageView
                                        android:id="@+id/ivPresetSocial"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/bg_common" />
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#66000000" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="bottom|center_horizontal"
                                        android:layout_marginBottom="6dp"
                                        android:gravity="center"
                                        android:text="Social"
                                        android:textColor="@color/colorWhite"
                                        android:textSize="11sp"
                                        android:fontFamily="sans-serif-medium" />
                                </FrameLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Preset 7: Nature -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/presetNature"
                                android:layout_width="88dp"
                                android:layout_height="64dp"
                                android:layout_marginEnd="8dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/colorLightGray"
                                app:strokeWidth="1dp">
                                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                    <ImageView
                                        android:id="@+id/ivPresetNature"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/bg_common" />
                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:background="#66000000" />
                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="bottom|center_horizontal"
                                        android:layout_marginBottom="6dp"
                                        android:gravity="center"
                                        android:text="Nature"
                                        android:textColor="@color/colorWhite"
                                        android:textSize="11sp"
                                        android:fontFamily="sans-serif-medium" />
                                </FrameLayout>
                            </com.google.android.material.card.MaterialCardView>

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Pinned Sticky Actions bottomBarCreate -->
    <LinearLayout
        android:id="@+id/bottomBarCreate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/colorWhite"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="@color/hc_text_secondary"
            app:cornerRadius="12dp"
            app:strokeColor="@color/colorLightGray" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateEvent"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:backgroundTint="@color/hc_accent"
            android:text="Create Event"
            android:textColor="@color/colorWhite"
            app:cornerRadius="12dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>