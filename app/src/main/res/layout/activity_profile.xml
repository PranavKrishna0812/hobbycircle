<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/profileScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hc_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero gradient banner -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_auth_overlay" />

            <!-- Diagonal arc overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.05"
                android:background="@android:color/white" />

            <!-- Profile title centered on hero -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProfileTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Your Profile"
                    android:textColor="@color/hc_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRoleBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_tag"
                    android:paddingLeft="12dp"
                    android:paddingTop="4dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="4dp"
                    android:text="@string/role_user"
                    android:textColor="@color/hc_primary_light"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- Form area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="32dp"
            android:paddingTop="24dp"
            android:paddingRight="32dp"
            android:paddingBottom="42dp">

            <!-- NAME label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:letterSpacing="0.06"
                android:text="NAME"
                android:textAllCaps="true"
                android:textColor="@color/hc_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Name"
                android:textColor="@color/hc_text_primary"
                android:textColorHint="@color/hc_text_secondary" />

            <!-- EMAIL label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:letterSpacing="0.06"
                android:text="EMAIL"
                android:textAllCaps="true"
                android:textColor="@color/hc_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Email"
                android:textColor="@color/hc_text_primary"
                android:textColorHint="@color/hc_text_secondary" />

            <!-- LOCATION label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:letterSpacing="0.06"
                android:text="LOCATION"
                android:textAllCaps="true"
                android:textColor="@color/hc_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Your city / area (for near you)"
                android:textColor="@color/hc_text_primary"
                android:textColorHint="@color/hc_text_secondary" />

            <!-- HOBBIES label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:letterSpacing="0.06"
                android:text="HOBBIES"
                android:textAllCaps="true"
                android:textColor="@color/hc_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etHobbies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input"
                android:hint="Hobbies (optional)"
                android:minLines="2"
                android:textColor="@color/hc_text_primary"
                android:textColorHint="@color/hc_text_secondary" />

            <!-- Save button -->
            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/ripple_primary_button"
                android:text="Save Profile"
                android:textAllCaps="false"
                android:textColor="@color/hc_button_text_on_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Section: Events You Created -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Events You Created"
                android:textColor="@color/hc_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCreatedEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false" />

            <!-- Logout button -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/ripple_outline_button"
                android:text="Logout"
                android:textAllCaps="false"
                android:textColor="@color/hc_accent"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>