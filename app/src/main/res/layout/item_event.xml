<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/eventItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/item_card_margin"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/colorWhite"
    app:cardCornerRadius="@dimen/item_card_corner_radius"
    app:cardElevation="@dimen/item_card_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivEventImage"
            android:layout_width="match_parent"
            android:layout_height="@dimen/event_image_height_item"
            android:contentDescription="Event Image"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/TopRoundedImage" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/item_content_padding_start"
            android:paddingTop="@dimen/item_content_padding_top"
            android:paddingEnd="@dimen/item_content_padding_end"
            android:paddingBottom="@dimen/item_content_padding_bottom">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHobby"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/chip_height"
                android:textColor="@color/hc_accent"
                android:textSize="@dimen/chip_text_size"
                app:chipBackgroundColor="@color/colorAccentSoft"
                app:chipCornerRadius="@dimen/chip_corner_radius_custom" />

            <TextView
                android:id="@+id/tvEventTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/item_title_margin_top"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/colorNavy"
                android:textSize="@dimen/event_title_text_size" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/event_info_margin_top"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/info_icon_size"
                    android:layout_height="@dimen/info_icon_size"
                    android:contentDescription="Date"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/hc_text_secondary" />

                <TextView
                    android:id="@+id/tvEventDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/info_icon_margin_start"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="@dimen/event_info_text_size" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0" />

                <ImageView
                    android:layout_width="@dimen/info_icon_size"
                    android:layout_height="@dimen/info_icon_size"
                    android:contentDescription="Location"
                    android:src="@drawable/ic_location"
                    app:tint="@color/hc_text_secondary" />

                <TextView
                    android:id="@+id/tvEventLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/info_icon_margin_start"
                    android:ellipsize="end"
                    android:maxWidth="@dimen/event_location_max_width"
                    android:singleLine="true"
                    android:textColor="@color/hc_text_secondary"
                    android:textSize="@dimen/event_info_text_size" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
