<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/hc_bg"
        android:orientation="vertical">

        <!-- Shared top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/hc_nav_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/screen_padding_horizontal"
            android:paddingTop="48dp"
            android:paddingRight="@dimen/screen_padding_horizontal"
            android:paddingBottom="10dp"
            android:elevation="2dp">

            <ImageButton
                android:id="@+id/btnDrawerMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Open navigation"
                android:src="@android:drawable/ic_menu_more"
                app:tint="@color/hc_primary_light" />

            <TextView
                android:id="@+id/tvDrawerTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Hobby Circle"
                android:textColor="@color/hc_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Content frame -->
        <FrameLayout
            android:id="@+id/drawerContentFrame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/hc_nav_bg"
        app:itemIconTint="@color/hc_primary_light"
        app:itemTextColor="@color/hc_text_primary"
        app:menu="@menu/menu_home_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>